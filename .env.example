# ─── App URL ───────────────────────────────────────────────────────────────────
# Set this to your Vercel deployment URL (no trailing slash)
# Example: https://nexaro.vercel.app
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# ─── Firebase Client SDK ───────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Google OAuth (Gmail + Calendar) ──────────────────────────────────────────
# Authorized redirect URIs to add in Google Cloud Console:
#   https://your-project.vercel.app/settings
#   https://your-project.vercel.app/settings?service=calendar
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Slack OAuth ───────────────────────────────────────────────────────────────
# Redirect URI to add in Slack App → OAuth & Permissions:
#   https://your-project.vercel.app/api/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://your-project.vercel.app/api/slack/callback
SLACK_BOT_TOKEN=

# ─── Microsoft OAuth (Outlook + Teams) ────────────────────────────────────────
# Redirect URI to add in Azure AD → App Registrations → Authentication:
#   https://your-project.vercel.app/api/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://your-project.vercel.app/api/microsoft/callback

# ─── AI (Groq) ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=
